# Supabase 配置
# 在 https://app.supabase.com 创建项目后获取
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 海王同步 - Cloudflare Worker 代理配置
# 所有对 admin.haiwangweb.com 的请求通过 Worker 代理转发，彻底绕过 Cloudflare 403。
# Worker 部署说明见 README.md（海王 Worker 代理接入）。
# 如不填写，使用内置默认值（bolong6233 worker + 默认 secret）。
HAIWANG_WORKER_PROXY_URL=https://haiwang-proxy.bolong6233.workers.dev/
HAIWANG_WORKER_PROXY_SECRET=haiwang-proxy-secret-key-2026

# 海王 API Key（可选，有默认值）
# HAIWANG_API_KEY=your_haiwang_api_key
