# Supabase 配置
# 在 https://app.supabase.com 创建项目后获取
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 验证码签名密钥（用于 HMAC 签名，建议使用至少 32 位随机字符串）
# 生成示例：openssl rand -base64 32
# 部署到 Vercel 时请在 Project Settings > Environment Variables 中设置
CAPTCHA_SECRET=replace-me-with-a-strong-random-secret
